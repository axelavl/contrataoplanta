DB_HOST=localhost
DB_PORT=5432
DB_NAME=empleospublicos
DB_USER=postgres
# Obligatorio — sin valor por defecto. La API aborta si falta.
DB_PASSWORD=change_me

SITE_URL=https://estadoemplea.pages.dev

# Autenticación del panel admin. Obligatorios — la API aborta si faltan.
# Genera un valor fuerte (ej: `openssl rand -hex 24`).
ADMIN_PASSWORD=
# Prefijo secreto para las rutas /api/<ADMIN_PATH>/... (ej: ADMIN_PATH=f8a3d2e7).
# Si no se define, cae a "_gestion_ops" (valor público, solo útil en dev).
ADMIN_PATH=

# Opcional: lista CSV de orígenes permitidos para CORS.
# CORS_ALLOW_ORIGINS=https://estadoemplea.pages.dev

RESEND_API_KEY=
EMAIL_FROM=alertas@estadoemplea.pages.dev

MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=
